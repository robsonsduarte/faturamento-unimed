      "typeVersion": 3,
      "position": [
        1800,
        0
      ],
      "parameters": {
        "operation": "download",
        "resource": "file",
        "fileId": {
          "__rl": true,
          "value": "={{ $json.bg_file_id }}",
          "mode": "id"
        },
        "options": {}
      },
      "credentials": {
        "googleDriveOAuth2Api": {
          "id": "G4InVzR5v9RWNF27",
          "name": "Google Drive robsonsduarte"
        }
      }
    },
