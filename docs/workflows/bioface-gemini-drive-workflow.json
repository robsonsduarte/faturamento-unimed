        "jsCode": "const bin = await this.helpers.getBinaryDataBuffer(0, 'data');\nconst b64 = Buffer.from(bin).toString('base64');\nconst ctx = $('09 \u2014 Split').item.json;\nreturn [{json: {...ctx, bg_base64: b64}}];"
      }
    },
    {
      "id": "n12",
      "name": "12 \u2014 Gemini",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        2200,
        0
      ],
      "parameters": {
        "method": "POST",
        "url": "https://generativelanguage.googleapis.com/v1beta/models/gemini-2.5-flash-image:generateContent?key=<GEMINI_API_KEY>",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "Content-Type",
              "value": "application/json"
            }
          ]
        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={{ JSON.stringify({\n  contents: [{\n    parts: [\n      { inline_data: { mime_type: 'image/jpeg', data: $json.patient_base64 } },\n      { inline_data: { mime_type: 'image/jpeg', data: $json.bg_base64 } },\n      { text: 'Compose image 1 (the person) into the environment of image 2 (the background scene). Place the person naturally in the foreground of the scene. Preserve the exact face, hair, identity and clothing of the person from image 1 unchanged. Match the lighting, color temperature and shadows of image 2 so the person looks like they naturally belong in that environment. Portrait framing, professional quality, photorealistic result.' }\n    ]\n  }]\n}) }}",
        "options": {
          "timeout": 60000
        }
      }
    },
    {
      "id": "n13",
      "name": "13 \u2014 Extract",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        2400,
        0
      ],
      "parameters": {
        "jsCode": "const resp = $input.first().json;\nconst parts = resp.candidates?.[0]?.content?.parts || [];\nconst imgPart = parts.find(p => p.inlineData);\nif (!imgPart) throw new Error('Gemini sem imagem: ' + JSON.stringify(resp).slice(0,300));\nconst ctx = $('11 \u2014 Base64 fundo').item.json;\nconst path = `${ctx.guia_id}/${ctx.record_id}/${ctx.bg_name_no_ext}.jpg`;\nconst binBuf = Buffer.from(imgPart.inlineData.data, 'base64');\nreturn [{\n  json: {\n    record_id: ctx.record_id,\n    guia_id: ctx.guia_id,\n    numero_carteira: ctx.numero_carteira,\n    operator_id: ctx.operator_id,\n    bg_name: ctx.bg_name_no_ext,\n    storage_path: path\n  },\n  binary: { data: await this.helpers.prepareBinaryData(binBuf, ctx.bg_name_no_ext + '.jpg', 'image/jpeg') }\n}];"
      }
    },
