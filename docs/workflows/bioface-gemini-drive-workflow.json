{
  "name": "Bioface \u2014 Gemini Nano Banana (Drive Backgrounds)",
  "nodes": [
    {
      "id": "n01",
      "name": "01 \u2014 Webhook",
      "type": "n8n-nodes-base.webhook",
      "typeVersion": 2,
      "position": [
        0,
        0
      ],
      "parameters": {
        "httpMethod": "POST",
        "path": "bioface-processed",
        "responseMode": "onReceived",
        "responseCode": 200,
        "options": {
          "rawBody": false
        }
      },
      "webhookId": "ac06301b-72dd-4be3-a060-77a7611ad2b3"
    },
    {
      "id": "n02",
      "name": "02 \u2014 Extrair",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        200,
        0
      ],
      "parameters": {
        "jsCode": "const headers = $input.first().json.headers;\nconst body = $input.first().json.body;\nconst expected = '<N8N_WEBHOOK_SECRET>';\nconst received = headers['x-api-key'] || headers['X-Api-Key'];\nif (!received || received !== expected) throw new Error('Unauthorized');\nconst record = body.record;\nif (!record || !record.id) throw new Error('Payload invalido');\nif (record.captured_by !== null && record.captured_by !== undefined) return [];\nif (!record.operator_id) return [];\nif (record.processing_status !== 'pending_ai') return [];\nreturn [{json: {\n  record_id: record.id,\n  guia_id: record.guia_id || null,\n  numero_carteira: record.numero_carteira,\n  photo_path: record.photo_path,\n  operator_id: record.operator_id,\n  sequence: record.sequence,\n}}];"
      }
    },
    {
      "id": "n02b",
      "name": "02b \u2014 Resolver guia_id",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        300,
        0
      ],
      "parameters": {
        "method": "GET",
        "url": "=https://mnrrjslmxcxcismwyaha.supabase.co/rest/v1/guias?numero_carteira=eq.{{ $json.numero_carteira }}&select=id,numero_carteira&order=created_at.desc&limit=1",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "apikey",
              "value": "<SUPABASE_SERVICE_KEY>"
            },
            {
              "name": "Authorization",
              "value": "Bearer <SUPABASE_SERVICE_KEY>"
            }
          ]
        },
        "options": {}
      }
    },
    {
      "id": "n02c",
      "name": "02c \u2014 Merge guia_id",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        350,
        0
      ],
      "parameters": {
        "jsCode": "const resp = $input.first().json;\nconst ctx = $(\"02 \u2014 Extrair\").first().json;\nconst guia_id = ctx.guia_id || resp?.id || null;\nif (!guia_id) {\n  console.log(\"[bioface] Nenhuma guia encontrada para\", ctx.numero_carteira);\n  return [];\n}\nreturn [{json: {...ctx, guia_id}}];"
      }
    },
    {
      "id": "n03",
