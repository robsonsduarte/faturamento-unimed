      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1000,
        0
      ],
      "parameters": {
        "jsCode": "const bin = await this.helpers.getBinaryDataBuffer(0, \"data\");\nconst b64 = Buffer.from(bin).toString(\"base64\");\nconst ctx = $(\"02c \u2014 Merge guia_id\").first().json;\nreturn [{json: {...ctx, patient_base64: b64}}];"
      }
    },
    {
      "id": "n07",
      "name": "07 \u2014 Listar Fundos (Drive)",
      "type": "n8n-nodes-base.googleDrive",
      "typeVersion": 3,
      "position": [
        1200,
        0
      ],
      "parameters": {
        "resource": "fileFolder",
        "returnAll": true,
        "filter": {
          "folderId": {
            "__rl": true,
            "value": "1g8RUJVDu6ja1ShW0eSXW5dIjkUTQnjQN",
            "mode": "id"
          }
        },
        "options": {}
      },
      "credentials": {
        "googleDriveOAuth2Api": {
          "id": "G4InVzR5v9RWNF27",
          "name": "Google Drive robsonsduarte"
        }
      }
    },
    {
      "id": "n07b",
      "name": "07b \u2014 Random 5",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1300,
        0
      ],
      "parameters": {
        "jsCode": "// Embaralha os items e pega 5 aleatorios\nconst items = $input.all();\nconst shuffled = [...items];\nfor (let i = shuffled.length - 1; i > 0; i--) {\n  const j = Math.floor(Math.random() * (i + 1));\n  [shuffled[i], shuffled[j]] = [shuffled[j], shuffled[i]];\n}\nconst picked = shuffled.slice(0, 5);\nconsole.log('[bioface] Total files:', items.length, '| Picked:', picked.length, '| Names:', picked.map(p => p.json.name));\nreturn picked;"
      }
    },
    {
      "id": "n08",
      "name": "08 \u2014 Preparar loop",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1400,
        0
      ],
      "parameters": {
        "jsCode": "const items = $input.all();\nconst ctx = $('06 \u2014 Base64 paciente').first().json;\n// items each has Drive file metadata\nreturn items.map(it => ({\n  json: {\n    ...ctx,\n    bg_file_id: it.json.id,\n    bg_file_name: it.json.name,\n    bg_name_no_ext: (it.json.name || 'bg').replace(/\\.[^.]+$/, '').toLowerCase().replace(/[^a-z0-9-]/g, '-'),\n  }\n}));"
      }
    },
    {
      "id": "n09",
      "name": "09 \u2014 Split",
      "type": "n8n-nodes-base.splitInBatches",
      "typeVersion": 3,
      "position": [
        1600,
        0
      ],
      "parameters": {
        "batchSize": 1,
        "options": {}
      }
    },
    {
      "id": "n10",
