      "parameters": {
        "jsCode": "const redisValue = $input.first().json.value;\nconst creds = $('Credenciais SAW').first().json;\n\nlet cookies = null;\nlet temCookies = false;\n\nif (redisValue && redisValue !== '' && redisValue !== 'null') {\n  try {\n    const parsed = JSON.parse(redisValue);\n    cookies = parsed.cookies || parsed;\n    temCookies = Array.isArray(cookies) && cookies.length > 0;\n    \n    const temJSession = cookies.some(c => c.name === 'JSESSIONID');\n    if (!temJSession) {\n      temCookies = false;\n      cookies = null;\n    }\n  } catch (e) {\n    console.log('Erro parse cookies:', e.message);\n  }\n}\n\nreturn [{\n  json: {\n    cookies,\n    temCookies,\n    API_URL: creds.API_URL,\n    SAW_USER: creds.SAW_USER,\n    SAW_PASSWORD: creds.SAW_PASSWORD,\n    SAW_LOGIN_URL: creds.SAW_LOGIN_URL,\n    COOKIE_KEY: creds.COOKIE_KEY\n  }\n}];"
      },
