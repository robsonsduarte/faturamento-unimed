    {
      "parameters": {
        "operation": "runCustomScript",
        "scriptCode": "const creds = $('Credenciais SAW').first().json;\nconst { SAW_USER: username, SAW_PASSWORD: password, SAW_LOGIN_URL: loginUrl } = creds;\n\nawait $page.setViewport({ width: 1280, height: 720 });\nawait $page.goto(loginUrl, { waitUntil: 'domcontentloaded', timeout: 30000 });\nawait new Promise(r => setTimeout(r, 3000));\n\n// Login\nfor (const [sel, val] of [['#login', username], ['#password', password]]) {\n  await $page.$eval(sel, el => el.value = '');\n  await $page.click(sel);\n  await $page.type(sel, val, { delay: 80 });\n}\n\nawait $page.click('#submitForm');\nawait new Promise(r => setTimeout(r, 15000));\n\n// Checar frames (SAW é sistema Java antigo, provavelmente usa framesets)\nconst resultado = await $page.evaluate(() => {\n  const frames = document.querySelectorAll('frame, iframe');\n  return {\n    url: window.location.href,\n    title: document.title,\n    numFrames: frames.length,\n    frames: Array.from(frames).map(f => ({ tag: f.tagName, src: f.src, id: f.id, name: f.name })),\n    allIds: Array.from(document.querySelectorAll('[id]')).slice(0, 20).map(el => el.id),\n    htmlSnippet: document.documentElement.innerHTML.substring(0, 1500)\n  };\n});\n\nreturn [{ json: resultado }];",
        "options": {
          "headless": true
        }
      },
