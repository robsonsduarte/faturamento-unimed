    {
      "parameters": {
        "operation": "runCustomScript",
        "scriptCode": "// ============================================\n// VALIDAR SESSÃO SAW - Puppeteer Community Node\n// $page e $browser já disponíveis pelo node\n// ============================================\nconst cookies = $('Preparar Cookies').first().json.cookies;\n\nconsole.log('[VALIDAR SESSÃO] Testando cookies...');\n\ntry {\n  // 1. Navegar para o domínio SAW para poder injetar cookies\n  await $page.goto('https://saw.trixti.com.br', {\n    waitUntil: 'domcontentloaded',\n    timeout: 20000\n  });\n\n  // 2. Injetar cookies da sessão\n  await $page.setCookie(...cookies);\n\n  // 3. Navegar para a página principal\n  await $page.goto('https://saw.trixti.com.br/saw/Principal.do', {\n    waitUntil: 'networkidle2',\n    timeout: 30000\n  });\n\n  await $page.waitForFunction(() => document.readyState === 'complete', {\n    timeout: 10000\n  }).catch(() => {});\n\n  // 4. Verificar se está logado\n  const valida = await $page.evaluate(() => {\n    return document.querySelector('#topoBarraPrincipal') !== null;\n  });\n\n  console.log('[VALIDAR SESSÃO] Resultado:', valida ? 'válida' : 'expirada');\n  return [{ json: { success: true, valida } }];\n\n} catch (error) {\n  console.error('[VALIDAR SESSÃO] Erro:', error.message);\n  return [{ json: { success: false, valida: false, erro: error.message } }];\n}",
        "options": {
          "headless": "new"
        }
      },
