      "parameters": {
        "jsCode": "const todasGuias = $input.all();\n\nconst guiasFiltradas = todasGuias.filter(item => {\n  const status = (item.json.status_guide || '').toString().toUpperCase().trim();\n  return status === 'COBRAR OU TOKEN' || status === 'CPRO';\n});\n\nif (guiasFiltradas.length === 0) {\n  return [{ json: { temGuias: false, mensagem: 'Nenhuma guia pendente' } }];\n}\n\nconsole.log('Guias filtradas:', guiasFiltradas.length, 'de', todasGuias.length, 'total');\n\nreturn guiasFiltradas.map(item => ({ json: { ...item.json, temGuias: true } }));"
