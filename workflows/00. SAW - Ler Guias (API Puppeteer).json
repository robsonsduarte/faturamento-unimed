    {
      "parameters": {
        "jsCode": "// Combinar dados do SAW + ConsultorioPro\nconst saw = $('Ler Guia (API)').first().json;\nconst cpro = $json;\nconst guiaOriginal = $('Tem Número Guia?').first().json;\n\nreturn [{\n  json: {\n    // Identificação\n    guide_number: saw.numeroGuia || guiaOriginal.guide_number,\n    row_number: guiaOriginal.row_number,\n    \n    // Dados do SAW\n    status: saw.status,\n    senha: saw.senha,\n    dataAutorizacao: saw.dataAutorizacao,\n    dataValidadeSenha: saw.dataValidadeSenha,\n    quantidadeSolicitada: saw.quantidadeSolicitada,\n    quantidadeAutorizada: saw.quantidadeAutorizada,\n    procedimentosRealizados: saw.procedimentosRealizados,\n    numeroCarteira: saw.numeroCarteira,\n    nomeBeneficiario: saw.nomeBeneficiario,\n    codigoPrestador: saw.codigoPrestador,\n    nomeProfissional: saw.nomeProfissional,\n    cnes: saw.cnes,\n    \n    // Dados do ConsultorioPro\n    procedimentosCadastrados: cpro.data?.totals?.count || 0,\n    userId: cpro.data?.attendances?.[0]?.professional?.id || null,\n    valorTotal: cpro.data?.attendances?.[0]?.value_formatted || null,\n    \n    // Status\n    sucesso: saw.success,\n    erro: saw.erro\n  }\n}];"
      },
