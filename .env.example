# ===========================================
# DuarteOS Core AI — Variaveis de Ambiente
# ===========================================
# Copie este arquivo para .env e preencha:
#   cp .env.example .env
#
# Depois carregue antes de abrir o Claude Code:
#   source .env && claude
#
# Ou use direnv (recomendado — carrega automatico):
#   brew install direnv  (macOS)
#   echo 'eval "$(direnv hook zsh)"' >> ~/.zshrc
#   direnv allow
# ===========================================

# --- BUSCA E PESQUISA ---

# EXA — busca web avancada, codigo, empresas
# Pegue em: https://dashboard.exa.ai/api-keys (gratis $15 de credito)
EXA_API_KEY=

# --- CONTEUDO ---

# --- BANCO DE DADOS ---

# Redis — persistencia de contexto, cache, sessoes
# Local: redis://localhost:6379
# Cloud: redis://user:password@host:port (ex: Upstash, Redis Cloud)
REDIS_URL=redis://localhost:6379

# --- DESENVOLVIMENTO ---

# GitHub — issues, PRs, code search + CodeRabbit (code review IA)
# Pegue em: https://github.com/settings/tokens (escopos: repo, read:org)
GITHUB_PAT=

# REST API — URL base da sua API (ex: https://api.meuapp.com)
REST_API_BASE_URL=

# Supabase — acesso direto ao banco
# Pegue em: Dashboard Supabase → Settings → General → Reference ID
SUPABASE_PROJECT_REF=

# --- AUTOMACAO ---

# n8n — gerencia workflows de automacao
# URL da instancia (ex: http://localhost:5678) + API key (Settings → API)
N8N_API_URL=
N8N_API_KEY=

# Google Workspace — Gmail, Drive, Calendar, Docs, Sheets
# Pegue em: https://console.cloud.google.com/apis/credentials
# Crie credencial OAuth 2.0 tipo "Desktop Application"
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=

# Obsidian — caminho local do vault
# Ex: /Users/seuusuario/Documents/Obsidian Vault
OBSIDIAN_VAULT_PATH=

# --- SANDBOX ---

# E2B — execucao segura de codigo em microVMs
# Pegue em: https://e2b.dev/dashboard (tem free tier)
E2B_API_KEY=
