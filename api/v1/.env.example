# =========================================
# ConsultorioPro REST API - Configurações
# =========================================

# IMPORTANTE: 
# 1. Copie este arquivo para .env
# 2. Preencha com suas credenciais reais
# 3. NUNCA commite o arquivo .env no Git

# =========================================
# Banco de Dados
# =========================================
DB_HOST=localhost
DB_PORT=3306
DB_NAME=consult6_cpro
DB_USER=consult6_cpro_user
DB_PASS=sua_senha_segura_aqui

# =========================================
# Ambiente
# =========================================
# Valores: development, production
ENVIRONMENT=development

# Mostrar erros detalhados? (true/false)
DEBUG_MODE=true

# Timezone
TIMEZONE=America/Bahia

# =========================================
# API
# =========================================
API_VERSION=1.0.0

# URL base da API (sem barra no final)
API_BASE_URL=https://consultoriopro.com.br/service/api/v1

# =========================================
# CORS - Domínios Permitidos
# =========================================
# Separe múltiplos domínios por vírgula
ALLOWED_ORIGINS=https://n8n.robsonduarte.com.br,https://consultoriopro.com.br,http://localhost:5678

# =========================================
# Rate Limiting
# =========================================
RATE_LIMIT_ENABLED=true
RATE_LIMIT_PER_MINUTE=60

# =========================================
# Logs
# =========================================
LOG_ENABLED=true
LOG_REQUESTS=true
LOG_ERRORS=true
LOG_DIR=../logs

# =========================================
# Cache
# =========================================
CACHE_ENABLED=false
CACHE_TTL=300

# =========================================
# Segurança
# =========================================
# Tempo máximo de execução (segundos)
REQUEST_TIMEOUT=30

# Tamanho máximo do corpo da requisição (MB)
MAX_BODY_SIZE=5
